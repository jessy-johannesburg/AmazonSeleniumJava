{
  "default": {
    "requireModule": ["ts-node/register"],
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "require": [
      "src/test/web/steps/*.ts",
      "src/test/api/api/steps/*.ts",
      "src/hooks/*.ts"
      
    ],
    "paths": [
      "src/test/web/features/**/*.feature",
      "src/test/api/api/features/**/*.feature"
    ],
    "format": [
      "json:test-results/web/cucumber-report.json",
      "html:test-results/web/cucumber-report.html"
    ]
  }
}